# Cool School AI - Railway Deployment Environment Variables

# Required - Change this to a secure random string
SECRET_KEY=your-super-secret-key-here-change-this-in-production

# Optional - Kimi API Key (if not set, uses default dev key)
KIMI_API_KEY=sk-your-kimi-api-key-here

# Railway automatically sets PORT - do not set manually
# PORT=5000
